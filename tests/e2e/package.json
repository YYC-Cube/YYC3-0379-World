{
  "name": "yyc3-e2e-tests",
  "version": "1.0.0",
  "description": "YYC³ E2E 测试套件",
  "scripts": {
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:debug": "playwright test --debug",
    "test:playwright:report": "playwright show-report",
    "test:cypress": "cypress run",
    "test:cypress:open": "cypress open",
    "test:cypress:headless": "cypress run --headless",
    "test:all": "npm run test:playwright && npm run test:cypress",
    "test:smoke": "playwright test tests/smoke",
    "test:regression": "playwright test tests/regression",
    "test:e2e": "playwright test tests/e2e"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.12.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "cypress": "^13.6.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "form-data": "^4.0.4",
    "tmp": "^0.2.3",
    "qs": "^6.14.0",
    "uuid": "^11.0.0",
    "js-yaml": "^4.1.0",
    "fast-uri": "^3.0.0",
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-modules-systemjs": "^7.26.0"
  }
}
